# ---- .NET build output ----
bin/
obj/
out/
[Dd]ebug/
[Rr]elease/
x64/
x86/
*.user
*.suo
*.userosscache
*.dbmdl

# ---- IDE / editor ----
.vs/
.vscode/
.idea/
*.swp

# ---- Test / coverage ----
[Tt]est[Rr]esult*/
coverage/
*.coverage
*.trx

# ---- SQLite transient files (never commit WAL/SHM; app DB itself is gitignored too) ----
*.db
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal

# ---- aitasks runtime state (kept local; not versioned) ----
.aitasks/

# ---- Vendored binaries (ffmpeg etc. are fetched/bundled, not committed) ----
# Match the executables and downloaded archives only — NOT source files named Ffmpeg*.cs / ffmpeg.md
# (Git is case-insensitive on Windows, so a bare `ffmpeg*` would wrongly ignore those).
vendor/
ffmpeg.exe
ffprobe.exe
ffplay.exe
/ffmpeg
/ffprobe
ffmpeg-*.zip
ffmpeg-*.tar.*

# ---- Runtime / downloaded artifacts & test leftovers ----
downloads/
*.tmp
*.partial

# ---- OS noise ----
Thumbs.db
.DS_Store

# ---- Secrets / signing keys (NEVER commit) ----
.keys/

# Publish output (TASK-075)
artifacts/
