<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="JustDownload.App.App"
             RequestedThemeVariant="Light">

  <!--
    Light is the product default (UI/UX bar §7); the theme service can switch to Dark or follow the OS
    (ThemeVariant.Default). Design tokens are merged from Styles/Tokens.axaml and shared app-wide.
  -->

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://JustDownload.App/Styles/Tokens.axaml" />
        <ResourceInclude Source="avares://JustDownload.App/Styles/ListResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <!-- DataGrid's Fluent control theme (its visuals are then overridden by Styles/ListView.axaml). -->
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <StyleInclude Source="avares://JustDownload.App/Styles/Shell.axaml" />
    <StyleInclude Source="avares://JustDownload.App/Styles/ListView.axaml" />

    <!-- Token-driven window surface (Inter is the default font via WithInterFont in Program). -->
    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource BgBrush}" />
    </Style>
  </Application.Styles>

</Application>
