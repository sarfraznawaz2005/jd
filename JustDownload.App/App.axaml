<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="JustDownload.App.App"
             RequestedThemeVariant="Default">

  <!-- "Default" follows the OS theme; light is the product default (UI/UX bar §7). -->

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

</Application>
