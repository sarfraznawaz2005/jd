<Project Sdk="Microsoft.NET.Sdk">

  <!--
    JustDownload.App — the Avalonia 11 UI (D1/D4). MVVM, no business logic here;
    it drives JustDownload.Core through service interfaces (architecture §6).
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <RootNamespace>JustDownload.App</RootNamespace>
    <AssemblyName>JustDownload.App</AssemblyName>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <!-- Windows exe icon (titlebar/taskbar/Explorer) — generated by build/windows/gen-app-icon.js (TASK-222)
         from the same brand mark the other platform packages use. -->
    <ApplicationIcon>..\build\windows\icon.ico</ApplicationIcon>
    <!--
      Required by the source-generated P/Invokes ([LibraryImport]) behind the completion taskbar flash in
      Services/TaskbarAttentionService.cs (TASK-226). As in JustDownload.Core, this only permits the
      generator's marshalling stubs; we author no unsafe code ourselves (CLAUDE.md §1).
    -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <!-- Embedded so Avalonia can load it at runtime for Window.Icon (MainWindow.axaml) — the same file the
         ApplicationIcon property above points at, referenced in place rather than duplicated (TASK-222). -->
    <AvaloniaResource Include="..\build\windows\icon.ico" Link="Assets\icon.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.18" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.18" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.18" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.18" />
    <!-- DataGrid powers the downloads list: sortable/reorderable/resizable, virtualized columns (TASK-051). -->
    <PackageReference Include="Avalonia.Controls.DataGrid" Version="11.3.13" />
    <!-- Avalonia.Diagnostics (dev tools) is Debug-only so it never ships in Release. -->
    <PackageReference Include="Avalonia.Diagnostics" Version="11.3.18" Condition="'$(Configuration)' == 'Debug'" />
    <!-- Container builder for the App's provider, built from Core's composition root (§6). -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
    <!-- MVVM toolkit (D1): ObservableObject / RelayCommand source generators. -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\JustDownload.Core\JustDownload.Core.csproj" />
    <!--
      The Native Messaging Host ships beside the app so browsers can launch it (D8, TASK-151).
      ReferenceOutputAssembly=false: the app doesn't call the host's code, it just needs it built and
      co-located. The copy targets below place its files next to JustDownload.App.exe; all other
      dependencies (Core, Sqlite, …) are already in the app output at the same versions.
    -->
    <ProjectReference Include="..\JustDownload.NativeHost\JustDownload.NativeHost.csproj"
                      ReferenceOutputAssembly="false" Private="false" />
  </ItemGroup>

  <!--
    Glob inside the targets (not a static ItemGroup) so the host's freshly-built files are picked up. Only
    for plain dev builds (no RuntimeIdentifier) — a RID build/publish gets the RID-correct host via
    PublishNativeHostForRid/CopyNativeHostToPublishOutput below; running this too would copy the build
    machine's own-OS apphost into a cross-published bundle (it lands in $(OutDir), which the SDK's publish
    step then sweeps into $(PublishDir) alongside the correct one) — TASK-078.
  -->
  <Target Name="CopyNativeHostToBuildOutput" AfterTargets="Build" Condition="'$(RuntimeIdentifier)' == ''">
    <ItemGroup>
      <_NativeHostFiles Include="$(MSBuildThisFileDirectory)..\JustDownload.NativeHost\bin\$(Configuration)\$(TargetFramework)\JustDownload.NativeHost.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_NativeHostFiles)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>

  <!--
    Publishing with a RuntimeIdentifier (per-OS profiles, docs/publishing.md) cross-targets a different OS
    than the machine doing the build (e.g. publishing linux-x64 from a Windows dev box, TASK-078). The plain
    NativeHost build output above is always an apphost for the *build* machine's OS, so copying it into a
    cross-published bundle would ship a Windows .exe inside a Linux/macOS package — unexecutable, silently
    breaking native messaging (D8) on that platform. Publish NativeHost itself for the App's RID first, then
    copy from that RID-specific output.
  -->
  <Target Name="PublishNativeHostForRid" BeforeTargets="Publish" Condition="'$(RuntimeIdentifier)' != ''">
    <MSBuild Projects="$(MSBuildThisFileDirectory)..\JustDownload.NativeHost\JustDownload.NativeHost.csproj"
             Targets="Restore;Publish"
             Properties="Configuration=$(Configuration);RuntimeIdentifier=$(RuntimeIdentifier);SelfContained=false;PublishProfile=;PublishDir=$(MSBuildThisFileDirectory)..\JustDownload.NativeHost\bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\publish\" />
  </Target>

  <Target Name="CopyNativeHostToPublishOutput" AfterTargets="Publish">
    <PropertyGroup>
      <_NativeHostBinDir Condition="'$(RuntimeIdentifier)' != ''">$(MSBuildThisFileDirectory)..\JustDownload.NativeHost\bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\publish\</_NativeHostBinDir>
      <_NativeHostBinDir Condition="'$(RuntimeIdentifier)' == ''">$(MSBuildThisFileDirectory)..\JustDownload.NativeHost\bin\$(Configuration)\$(TargetFramework)\</_NativeHostBinDir>
    </PropertyGroup>
    <ItemGroup>
      <_NativeHostFiles Include="$(_NativeHostBinDir)JustDownload.NativeHost.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_NativeHostFiles)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
