<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Downloads-list visual resources (TASK-051): the per-category file-type glyphs and their colour tints,
    matching mockups/styles.css (.ft-video/.ft-audio/...). Tints are fixed brand colours that read on both
    light and dark, so they live in the base dictionary (not the theme dictionaries) and resolve once.
    Keys are produced by CategoryVisuals; the CategoryResourceConverter looks them up.
  -->

  <!-- Category glyphs (16x16 silhouettes for PathIcon). -->
  <StreamGeometry x:Key="IconCatVideo">M4,3 L13,8 L4,13 Z</StreamGeometry>
  <StreamGeometry x:Key="IconCatAudio">M3,6 H5.2 L8.5,3 V13 L5.2,10 H3 Z M10,5.5 A3.4,3.4 0 0 1 10,10.5 V9 A2,2 0 0 0 10,7 Z</StreamGeometry>
  <StreamGeometry x:Key="IconCatDocument">M4,2.5 H9.5 L12,5 V13.5 H4 Z M5.5,7.5 H10.5 V8.6 H5.5 Z M5.5,9.8 H10.5 V10.9 H5.5 Z</StreamGeometry>
  <StreamGeometry x:Key="IconCatCompressed">M3,2.8 H13 V5.6 H3 Z M3.6,5.6 H12.4 V13 H3.6 Z M7,7.2 H9 V9.4 H7 Z</StreamGeometry>
  <StreamGeometry x:Key="IconCatProgram">M3,3 H7 V7 H3 Z M9,3 H13 V7 H9 Z M3,9 H7 V13 H3 Z M9,9 H13 V13 H9 Z</StreamGeometry>
  <StreamGeometry x:Key="IconCatImage">M2.6,3 H13.4 V13 H2.6 Z M3.8,11.6 L6.8,7.6 L9,10.2 L10.8,8 L12.2,11.6 Z M10.7,4.6 A1.2,1.2 0 1 1 10.69,4.6 Z</StreamGeometry>
  <StreamGeometry x:Key="IconCatOther">M4,2.5 H9 L12,5.5 V13.5 H4 Z</StreamGeometry>

  <!-- Sidebar nav-node icons (TASK-050): All Downloads / Incomplete / Completed. -->
  <StreamGeometry x:Key="IconNavAll">M3,4 H13 V5.3 H3 Z M3,7.3 H13 V8.6 H3 Z M3,10.6 H13 V11.9 H3 Z</StreamGeometry>
  <StreamGeometry x:Key="IconNavIncomplete">M8,1.5 A6.5,6.5 0 1 1 7.99,1.5 Z M7.2,4.5 H8.8 V8.3 L11,10 L10.1,11.2 L7.2,9 Z</StreamGeometry>
  <StreamGeometry x:Key="IconNavComplete">M8,1.5 A6.5,6.5 0 1 1 7.99,1.5 Z M4.8,8 L7,10.2 L11.2,5.6 L10.1,4.6 L7,8 L5.9,6.9 Z</StreamGeometry>

  <!-- Settings-section nav icons (TASK-057). -->
  <StreamGeometry x:Key="IconSetGeneral">M7,2 H9 V4 H7 Z M7,12 H9 V14 H7 Z M2,7 H4 V9 H2 Z M12,7 H14 V9 H12 Z M8,5 A3,3 0 1 1 7.99,5 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSetConnections">M9,1.5 L4,9 H7.5 L7,14.5 L12,7 H8.5 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSetVideo">M8,1.5 A6.5,6.5 0 1 1 7.99,1.5 Z M6.5,5 L11,8 L6.5,11 Z</StreamGeometry>
  <!-- Same defect as the three below: the equator/meridian lines were open strokes with zero fill area
       (the meridian curves also can't show against a solid same-colour disc either way — dropped rather
       than faked with an invisible overlap). The equator is now a filled band whose ends poke past the
       circle's silhouette, same idea as the original but actually renders. -->
  <StreamGeometry x:Key="IconSetProxy">M8,1.5 A6.5,6.5 0 1 1 7.99,1.5 Z M2,7.4 H14 V8.6 H2 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSetAuth">M10.5,2.5 A3,3 0 1 0 7.7,6.7 L4,10.4 V12.5 H6 L6.5,11 H8 V9.5 H9.3 L10.5,8.3 A3,3 0 0 0 10.5,2.5 Z M11,4.2 A0.9,0.9 0 1 1 10.99,4.2 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSetCategories">M2,3.5 H6.5 L8,5 H14 V12.5 H2 Z</StreamGeometry>
  <!-- These three were originally authored as open stroke-style paths (a bare line/arc with no closing
       segment has zero fill area), so PathIcon's fill rendered them as invisible or as odd auto-closed
       slivers — "broken-looking"/missing icons (user-reported). Rebuilt from the same closed-shape
       technique as every other icon here (thin filled rects, full circles via a near-360° arc back to
       start). -->
  <StreamGeometry x:Key="IconSetBrowsers">M2,3 H14 V4.6 H2 Z M2,6 H14 V13 H2 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSetAdvanced">M2,3.4 H14 V4.6 H2 Z M7.6,4 A1.6,1.6 0 1 1 7.59,4 Z M2,7.4 H14 V8.6 H2 Z M11.6,8 A1.6,1.6 0 1 1 11.59,8 Z M2,11.4 H14 V12.6 H2 Z M5.6,12 A1.6,1.6 0 1 1 5.59,12 Z</StreamGeometry>
  <StreamGeometry x:Key="IconSetUpdates">M7,14 H9 V8 H11.5 L8,4.5 L4.5,8 H7 Z M3.5,3 H12.5 V1.5 H3.5 Z</StreamGeometry>

  <!-- Category tints (foreground glyph + tile background). -->
  <SolidColorBrush x:Key="CatVideoFg" Color="#f2565b" />
  <SolidColorBrush x:Key="CatVideoBg" Color="#25f2565b" />
  <SolidColorBrush x:Key="CatAudioFg" Color="#1faf57" />
  <SolidColorBrush x:Key="CatAudioBg" Color="#243ecf73" />
  <SolidColorBrush x:Key="CatDocumentFg" Color="#5b67d6" />
  <SolidColorBrush x:Key="CatDocumentBg" Color="#285e6ad2" />
  <SolidColorBrush x:Key="CatCompressedFg" Color="#b9770a" />
  <SolidColorBrush x:Key="CatCompressedBg" Color="#28e3a008" />
  <SolidColorBrush x:Key="CatProgramFg" Color="#6b6b75" />
  <SolidColorBrush x:Key="CatProgramBg" Color="#28969699" />
  <SolidColorBrush x:Key="CatImageFg" Color="#1bb6cb" />
  <SolidColorBrush x:Key="CatImageBg" Color="#2500b4c8" />
  <SolidColorBrush x:Key="CatOtherFg" Color="#6b6b75" />
  <SolidColorBrush x:Key="CatOtherBg" Color="#28969699" />
</ResourceDictionary>
