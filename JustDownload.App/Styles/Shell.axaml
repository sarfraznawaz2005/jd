<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Shell component styles (TASK-047) matching mockups/styles.css: the toolbar, sidebar nav, buttons,
    cards and status bar. Buttons use a single flat template (class "App") so colours come purely from
    the design tokens, keeping the look predictable across light/dark instead of fighting the Fluent
    button visuals.
  -->

  <!-- Flat button base: colours/padding come from the token classes below. -->
  <Style Selector="Button.App">
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="FontSize" Value="{StaticResource FontSm}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <!-- Default (secondary) button -->
  <Style Selector="Button.App">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <!-- Disabled: dimmed and non-interactive, so context-driven enablement is visible (TASK-052 AC2). -->
  <Style Selector="Button.App:disabled">
    <Setter Property="Opacity" Value="0.4" />
    <Setter Property="Cursor" Value="Arrow" />
  </Style>
  <Style Selector="Button.App:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
  </Style>

  <!-- Accent (primary) -->
  <Style Selector="Button.App.Accent">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.App.Accent:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
  </Style>

  <!-- Ghost (borderless icon) -->
  <Style Selector="Button.App.Ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
  </Style>
  <Style Selector="Button.App.Ghost:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <!-- Square icon-only -->
  <Style Selector="Button.App.IconOnly">
    <Setter Property="Width" Value="32" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <!-- Destructive (Cancel): red text on a card surface, red wash on hover. -->
  <Style Selector="Button.App.Danger">
    <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
  </Style>
  <Style Selector="Button.App.Danger:pointerover">
    <Setter Property="Background" Value="{DynamicResource RedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
  </Style>

  <!-- Destructive (delete): ghost until hovered, then a red wash so the consequence reads clearly. -->
  <Style Selector="Button.App.Ghost.Danger:pointerover">
    <Setter Property="Background" Value="{DynamicResource RedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <Style Selector="Button.App.Ghost.Danger:disabled">
    <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
  </Style>

  <!-- Sidebar nav item -->
  <Style Selector="Button.Nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="3,0,0,0" />
    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="Margin" Value="0,1" />
    <Setter Property="FontSize" Value="{StaticResource FontMd}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.Nav:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="Button.Nav.Active">
    <Setter Property="Background" Value="{DynamicResource SelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="Button.Nav.Child">
    <Setter Property="Margin" Value="18,1,0,1" />
    <Setter Property="Height" Value="29" />
  </Style>

  <!-- Section label -->
  <Style Selector="TextBlock.NavLabel">
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
    <Setter Property="Margin" Value="10,6,0,4" />
  </Style>

  <!-- Count pill -->
  <Style Selector="Border.CountPill">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="7,0" />
    <Setter Property="MinWidth" Value="20" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.CountPill > TextBlock">
    <Setter Property="FontSize" Value="{StaticResource FontXs}" />
    <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <!-- Detail view stat labels/values (TASK-054). -->
  <Style Selector="TextBlock.StatKey">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
  </Style>
  <Style Selector="TextBlock.StatValue">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBlock.OptionValue">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <!-- Card surface -->
  <Style Selector="Border.Card">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
  </Style>
</Styles>
