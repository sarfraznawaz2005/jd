<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JustDownload.App.ViewModels"
             xmlns:conv="using:JustDownload.App.Converters"
             x:Class="JustDownload.App.Views.DownloadDetailView"
             x:DataType="vm:DownloadDetailViewModel">

  <UserControl.Resources>
    <StreamGeometry x:Key="IconFolderSm">M2,3.5 H6.5 L8,5 H14 V12.5 H2 Z</StreamGeometry>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- The Fluent theme's default TabItem header size reads oversized in this narrow detail pane; bold
         headers plus a tighter selection-underline gap read more deliberate (user-reported). -->
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
      <Setter Property="Margin" Value="0" />
    </Style>
  </UserControl.Styles>

  <Panel>
    <!-- Empty state when nothing is selected -->
    <StackPanel Name="DetailEmptyState" IsVisible="{Binding !HasSelection}"
                HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="240" Spacing="6">
      <TextBlock Text="No download selected" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextDimBrush}" />
      <TextBlock Text="Select a download to see its progress, segments, and options."
                 TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFaintBrush}" />
    </StackPanel>

    <!-- Detail content -->
    <DockPanel IsVisible="{Binding HasSelection}" Margin="16">

      <!-- Header -->
      <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,14">
        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="{StaticResource RadiusSm}" Margin="0,0,12,0"
                Background="{Binding Selected.Category, Converter={x:Static conv:CategoryResourceConverter.Instance}, ConverterParameter=background}">
          <PathIcon Width="21" Height="21"
                    Data="{Binding Selected.Category, Converter={x:Static conv:CategoryResourceConverter.Instance}, ConverterParameter=geometry}"
                    Foreground="{Binding Selected.Category, Converter={x:Static conv:CategoryResourceConverter.Instance}, ConverterParameter=foreground}" />
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding Selected.FileName}" FontSize="13" FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextBrush}" />
          <TextBlock Text="{Binding Selected.SubLine}" FontSize="11.5" Foreground="{DynamicResource TextFaintBrush}" />
        </StackPanel>
      </Grid>

      <!-- Per-item actions -->
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,14,0,0">
        <Button Classes="App" Command="{Binding ResumeCommand}" Content="Resume" />
        <Button Classes="App" Command="{Binding PauseCommand}" Content="Pause" />
        <Button Classes="App Danger" Command="{Binding CancelCommand}" Content="Cancel" />
      </StackPanel>

      <!-- Tabs -->
      <TabControl SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">

        <!-- Download -->
        <TabItem Header="Download">
          <ScrollViewer>
            <StackPanel Spacing="16" Margin="0,12,0,0">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding Selected.StatusLabel}" FontSize="13"
                           Foreground="{DynamicResource TextDimBrush}" />
                <ProgressBar Classes="Mini" Minimum="0" Maximum="100" Value="{Binding Selected.ProgressPercent}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" >
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                  <TextBlock Text="Total size" Classes="StatKey" />
                  <TextBlock Text="{Binding TotalSizeDisplay}" Classes="StatValue" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                  <TextBlock Text="Downloaded" Classes="StatKey" />
                  <TextBlock Text="{Binding DownloadedDisplay}" Classes="StatValue" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0">
                  <TextBlock Text="Bandwidth" Classes="StatKey" />
                  <TextBlock Text="{Binding Selected.SpeedDisplay}" Classes="StatValue" Foreground="{DynamicResource AccentHoverBrush}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                  <TextBlock Text="Time left" Classes="StatKey" />
                  <TextBlock Text="{Binding Selected.EtaDisplay}" Classes="StatValue" />
                </StackPanel>
              </Grid>

              <!-- Recent speed sparkline (TASK-137) -->
              <StackPanel Spacing="6">
                <TextBlock Text="Speed (recent)" Classes="StatKey" />
                <!-- Fixed to its max width (60 bars * 3px + 59 * 1px spacing) so the card doesn't keep
                     growing wider for the sparkline's first 60 seconds — an ItemsControl otherwise sizes to
                     its current bar count. -->
                <Border Background="{DynamicResource CardBrush}" CornerRadius="4" Padding="6" Height="36" Width="251">
                  <ItemsControl ItemsSource="{Binding SpeedHistory.Bars}" VerticalAlignment="Bottom">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Spacing="1" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SpeedBar">
                        <Rectangle Width="3" Height="{Binding Height}" VerticalAlignment="Bottom"
                                   Fill="{DynamicResource AccentBrush}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </StackPanel>

              <!-- Live segment/connection visualization (TASK-055): one stacked strip per stream. -->
              <ItemsControl ItemsSource="{Binding Segments.Streams}" IsVisible="{Binding Segments.HasStreams}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:StreamStripViewModel">
                    <StackPanel Spacing="6" Margin="0,0,0,14">
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Label, StringFormat='{}{0} stream'}" Classes="StatKey" />
                        <TextBlock Text="{Binding SegmentCount, StringFormat='Segments: {0}'}" Classes="StatKey" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding Cells}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SegmentCellViewModel">
                            <ProgressBar Classes="SegCell" Orientation="Vertical" Minimum="0" Maximum="100"
                                         Value="{Binding FillPercent}" Margin="0,0,4,4" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="Waiting for connections…" IsVisible="{Binding ShowWaitingForConnections}"
                         FontSize="11.5" Foreground="{DynamicResource TextFaintBrush}" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- Options -->
        <TabItem Header="Options">
          <ScrollViewer>
            <StackPanel Spacing="14" Margin="0,12,0,0">
              <StackPanel Spacing="4">
                <TextBlock Text="File name" Classes="StatKey" />
                <TextBlock Text="{Binding Selected.FileName}" Classes="OptionValue" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Save to" Classes="StatKey" />
                <TextBlock Text="{Binding SaveToDisplay}" Classes="OptionValue" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Source URL" Classes="StatKey" />
                <TextBlock Text="{Binding UrlDisplay}" Classes="OptionValue" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Category" Classes="StatKey" />
                <TextBlock Text="{Binding CategoryDisplay}" Classes="OptionValue" />
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock Text="Verify checksum" Classes="StatKey" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0"
                           Watermark="Paste an MD5 or SHA-256 hash"
                           Text="{Binding ExpectedChecksum}" />
                  <Button Grid.Column="1"
                          Content="Verify"
                          Command="{Binding VerifyChecksumCommand}" />
                </Grid>
                <TextBlock Text="{Binding ChecksumStatus}"
                           Classes="OptionValue"
                           IsVisible="{Binding ChecksumStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- Connections -->
        <TabItem Header="Connections">
          <Panel Margin="0,12,0,0">
            <TextBlock Text="No active connections." IsVisible="{Binding !Connections.Count}"
                       Foreground="{DynamicResource TextFaintBrush}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <DataGrid Name="ConnectionsGrid" ItemsSource="{Binding Connections}"
                      IsVisible="{Binding Connections.Count}"
                      CanUserReorderColumns="False" CanUserSortColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None">
              <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding DisplayNumber}" Width="40" />
                <DataGridTextColumn Header="Range" Binding="{Binding RangeDisplay}" Width="*" />
                <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedDisplay}" Width="100" />
                <DataGridTextColumn Header="Speed" Binding="{Binding SpeedDisplay}" Width="90" />
                <DataGridTemplateColumn Header="Progress" Width="120">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate x:DataType="vm:ConnectionRowViewModel">
                      <ProgressBar Classes="Mini" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"
                                   VerticalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="State" Binding="{Binding StateDisplay}" Width="70" />
              </DataGrid.Columns>
            </DataGrid>
          </Panel>
        </TabItem>
      </TabControl>
    </DockPanel>
  </Panel>
</UserControl>
