<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustDownload.App.ViewModels"
        xmlns:views="using:JustDownload.App.Views"
        x:Class="JustDownload.App.Views.DownloadDetailWindow"
        x:DataType="vm:DownloadDetailViewModel"
        Title="Download details"
        Width="460" Height="560"
        MinWidth="380" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CardBrush}">
  <views:DownloadDetailView />
</Window>
