<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustDownload.App.ViewModels"
        xmlns:conv="using:JustDownload.App.Converters"
        xmlns:views="using:JustDownload.App.Views"
        x:Class="JustDownload.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="JustDownload"
        Width="1080" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Classes.compact="{Binding IsCompact}">

  <Window.Resources>
    <!-- Compact icon set (filled silhouettes for PathIcon). The full category icon set lands with the list view. -->
    <StreamGeometry x:Key="IconDownload">M7,2 H9 V8 H11.5 L8,11.5 L4.5,8 H7 Z M3.5,13 H12.5 V14.5 H3.5 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPlus">M7,2.5 H9 V7 H13.5 V9 H9 V13.5 H7 V9 H2.5 V7 H7 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPlay">M5,3.5 L12.5,8 L5,12.5 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPause">M4.5,3.5 H6.5 V12.5 H4.5 Z M9.5,3.5 H11.5 V12.5 H9.5 Z</StreamGeometry>
    <StreamGeometry x:Key="IconStop">M4.5,4.5 H11.5 V11.5 H4.5 Z</StreamGeometry>
    <!-- Second pass (first: d9ce38f): the lid/handle strips were still only 1.5 units thick against the
         7-9 unit solid blocks of Play/Pause/Stop, reading "slimmer" despite similar overall silhouette size
         (user-reported). Thickened both strips (1.5 → ~2) to close that visual-weight gap. -->
    <StreamGeometry x:Key="IconTrash">M6,2.3 H10 V4.3 H6 Z M3.3,4.3 H12.7 V6.5 H3.3 Z M4.7,6.5 H11.3 L10.6,14 H5.4 Z</StreamGeometry>
    <StreamGeometry x:Key="IconGear">M7,2 H9 V4 H7 Z M7,12 H9 V14 H7 Z M2,7 H4 V9 H2 Z M12,7 H14 V9 H12 Z M8,5 A3,3 0 1 1 7.99,5 Z</StreamGeometry>
    <StreamGeometry x:Key="IconList">M3,4 H13 V5.3 H3 Z M3,7.3 H13 V8.6 H3 Z M3,10.6 H13 V11.9 H3 Z</StreamGeometry>
    <StreamGeometry x:Key="IconFile">M4,2.5 H9 L12,5.5 V13.5 H4 Z</StreamGeometry>
    <StreamGeometry x:Key="IconInfo">M8,1.5 A6.5,6.5 0 1 1 7.99,1.5 Z M7.1,6.6 H8.9 V12 H7.1 Z M7,4 H9 V5.8 H7 Z</StreamGeometry>
    <!-- A framed panel with its right half solid — "toggle the detail panel" (mirrors IconList's toggle-sidebar
         glyph on the opposite side of the toolbar). -->
    <StreamGeometry x:Key="IconPanelToggle">M3,3 H4.2 V13 H3 Z M3,3 H9.4 V4.2 H3 Z M3,11.8 H9.4 V13 H3 Z M9.4,3 H13 V13 H9.4 Z</StreamGeometry>
  </Window.Resources>

  <!-- Keyboard shortcuts for the primary flows (TASK-059 AC0). -->
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewDownloadCommand}" />
    <KeyBinding Gesture="Delete" Command="{Binding Downloads.RemoveCommand}" />
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding ToggleDensityCommand}" />
    <!-- Command palette: Ctrl+K (Win/Linux) and Cmd+K (macOS). -->
    <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenPaletteCommand}" />
    <KeyBinding Gesture="Meta+K" Command="{Binding OpenPaletteCommand}" />
  </Window.KeyBindings>

  <Panel>
  <DockPanel>

    <!-- ===== Toolbar ===== -->
    <Border DockPanel.Dock="Top" Name="Toolbar" Background="{DynamicResource HeaderBrush}"
            Height="{StaticResource ToolbarHeight}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="False" Margin="14,0">

        <!-- Sidebar toggle -->
        <Button DockPanel.Dock="Left" Classes="App Ghost IconOnly" VerticalAlignment="Center" Margin="0,0,6,0"
                Command="{Binding ToggleSidebarCommand}" AutomationProperties.Name="Toggle sidebar" ToolTip.Tip="Toggle sidebar">
          <PathIcon Data="{StaticResource IconList}" Width="15" Height="15" />
        </Button>

        <!-- Brand -->
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="0,0,6,0">
          <Border Width="22" Height="22" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource AccentBrush}">
            <PathIcon Data="{StaticResource IconDownload}" Width="13" Height="13" Foreground="{DynamicResource OnAccentBrush}" />
          </Border>
          <TextBlock Text="JustDownload" FontWeight="SemiBold" FontSize="13.5" VerticalAlignment="Center"
                     Foreground="{DynamicResource TextBrush}" />
        </StackPanel>

        <!-- Primary action -->
        <Button DockPanel.Dock="Left" Classes="App Accent" VerticalAlignment="Center" Margin="10,0,0,0"
                Command="{Binding NewDownloadCommand}" AutomationProperties.Name="New download (Ctrl+N)" ToolTip.Tip="New download (Ctrl+N)">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <PathIcon Data="{StaticResource IconPlus}" Width="12" Height="12" />
            <TextBlock Text="New URL" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Transport group: act on the selected download (Stop pauses all active) -->
        <Border DockPanel.Dock="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource RadiusSm}">
          <StackPanel Orientation="Horizontal">
            <Button Classes="App Ghost" Width="34" AutomationProperties.Name="Resume" ToolTip.Tip="Resume" Command="{Binding Downloads.ResumeCommand}">
              <PathIcon Data="{StaticResource IconPlay}" Width="14" Height="14" />
            </Button>
            <Button Classes="App Ghost" Width="34" AutomationProperties.Name="Pause" ToolTip.Tip="Pause" Command="{Binding Downloads.PauseCommand}">
              <PathIcon Data="{StaticResource IconPause}" Width="14" Height="14" />
            </Button>
            <Button Classes="App Ghost" Width="34" AutomationProperties.Name="Stop all" ToolTip.Tip="Stop all" Command="{Binding Downloads.StopAllCommand}">
              <PathIcon Data="{StaticResource IconStop}" Width="14" Height="14" />
            </Button>
            <Button Classes="App Ghost Danger" Width="34" AutomationProperties.Name="Remove" ToolTip.Tip="Remove" Command="{Binding Downloads.RemoveCommand}">
              <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" />
            </Button>
          </StackPanel>
        </Border>

        <!-- Right cluster -->
        <Button DockPanel.Dock="Right" Classes="App Ghost IconOnly" VerticalAlignment="Center"
                Command="{Binding ToggleThemeCommand}" AutomationProperties.Name="Toggle theme" ToolTip.Tip="Toggle theme">
          <Ellipse Width="14" Height="14" Stroke="{DynamicResource TextDimBrush}" StrokeThickness="1.6" />
        </Button>
        <Button DockPanel.Dock="Right" Classes="App Ghost IconOnly" VerticalAlignment="Center" AutomationProperties.Name="About JustDownload" ToolTip.Tip="About JustDownload">
          <PathIcon Data="{StaticResource IconInfo}" Width="15" Height="15" />
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedRight">
              <StackPanel Width="240" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Border Width="26" Height="26" CornerRadius="{StaticResource RadiusSm}" Background="{DynamicResource AccentBrush}">
                    <PathIcon Data="{StaticResource IconDownload}" Width="15" Height="15" Foreground="{DynamicResource OnAccentBrush}" />
                  </Border>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="JustDownload" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}" FontSize="11"
                               Foreground="{DynamicResource TextFaintBrush}" />
                  </StackPanel>
                </StackPanel>
                <TextBlock Text="Cross-platform, light &amp; fast download manager."
                           TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
                <TextBlock Text="Free &amp; open source · MIT License" FontSize="11"
                           Foreground="{DynamicResource TextFaintBrush}" />
              </StackPanel>
            </Flyout>
          </Button.Flyout>
        </Button>
        <Button DockPanel.Dock="Right" Classes="App Ghost IconOnly" VerticalAlignment="Center" Margin="2,0"
                Command="{Binding OpenSettingsCommand}" AutomationProperties.Name="Settings" ToolTip.Tip="Settings">
          <PathIcon Data="{StaticResource IconGear}" Width="15" Height="15" />
        </Button>
        <Button DockPanel.Dock="Right" Classes="App Ghost IconOnly" VerticalAlignment="Center"
                Command="{Binding ToggleDetailCommand}" AutomationProperties.Name="Toggle details" ToolTip.Tip="Toggle details">
          <PathIcon Data="{StaticResource IconPanelToggle}" Width="15" Height="15" />
        </Button>
      </DockPanel>
    </Border>

    <!-- ===== Status bar ===== -->
    <Border DockPanel.Dock="Bottom" Name="StatusBar" Background="{DynamicResource HeaderBrush}"
            Height="{StaticResource StatusBarHeight}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel Margin="14,0" LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="{DynamicResource GreenBrush}" />
          <TextBlock Text="{Binding Status.ActiveCount, StringFormat='{}{0} active'}" FontSize="11.5"
                     FontWeight="Bold" Foreground="{DynamicResource TextDimBrush}" />
        </StackPanel>
        <!-- Right after "active" rather than after "Total speed" (user-reported ordering preference). -->
        <TextBlock DockPanel.Dock="Left" Text="{Binding Status.Connections, StringFormat='{}{0} connections'}"
                   Margin="18,0,0,0" FontSize="11.5" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" Margin="18,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="{Binding Status.TotalSpeedDisplay, StringFormat='Total speed {0}'}"
                     FontSize="11.5" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
          <!-- Aggregate speed sparkline (TASK-137). Fixed to its max width (60 bars * 2px) so it doesn't
               visibly drift its siblings right as bars accumulate over the sparkline's first 60 seconds
               (user-reported) — an ItemsControl otherwise sizes to its current bar count. -->
          <ItemsControl ItemsSource="{Binding Status.SpeedHistory.Bars}" Width="120" Height="24" VerticalAlignment="Center"
                        ToolTip.Tip="Recent combined speed">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SpeedBar">
                <Rectangle Width="2" Height="{Binding Height}" VerticalAlignment="Bottom"
                           Fill="{DynamicResource AccentBrush}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" Text="Speed limit: Unlimited" FontSize="11.5" FontWeight="Bold"
                   VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
      </DockPanel>
    </Border>

    <!-- ===== Body: three-pane master/detail (PRD 2.4.1) ===== -->
    <Grid Name="BodyGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" MinWidth="320" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="360" MinWidth="280" />
      </Grid.ColumnDefinitions>

      <!-- Sidebar (collapsible) -->
      <Border Grid.Column="0" Name="Sidebar" Width="232" IsVisible="{Binding SidebarVisible}"
              Background="{DynamicResource SidebarBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
        <ScrollViewer>
          <!-- Category-tree (TASK-050), data-driven from the sidebar view-model. -->
          <StackPanel Name="SidebarNav" Margin="8,12" DataContext="{Binding Sidebar}">
            <StackPanel.Resources>
              <DataTemplate x:Key="NavNodeTemplate" x:DataType="vm:SidebarNodeViewModel">
                <Button Classes="Nav" Classes.Active="{Binding IsSelected}" Classes.Child="{Binding IsChild}"
                        Command="{Binding #SidebarNav.((vm:SidebarViewModel)DataContext).SelectCommand}"
                        CommandParameter="{Binding}">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <PathIcon Grid.Column="0" Width="15" Height="15" Margin="0,0,10,0"
                              Data="{Binding IconKey, Converter={x:Static conv:ResourceKeyConverter.Instance}}"
                              Foreground="{DynamicResource TextFaintBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" />
                    <Border Grid.Column="2" Classes="CountPill"><TextBlock Text="{Binding Count}" /></Border>
                  </Grid>
                </Button>
              </DataTemplate>
            </StackPanel.Resources>

            <TextBlock Classes="NavLabel" Text="LIBRARY" />
            <ItemsControl ItemsSource="{Binding Nodes}" ItemTemplate="{StaticResource NavNodeTemplate}" />

            <TextBlock Classes="NavLabel" Text="STATUS" Margin="10,16,0,4" />
            <ItemsControl ItemsSource="{Binding StatusNodes}" ItemTemplate="{StaticResource NavNodeTemplate}" />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- List pane: the virtualized downloads grid (TASK-051), with the empty state when there are none. -->
      <Border Grid.Column="1" Name="ListPane" Background="{DynamicResource BgBrush}">
        <Grid RowDefinitions="Auto,*">

          <!-- Search & filter bar (TASK-134): free-text over name/URL, plus status and date filters. -->
          <Border Grid.Row="0" Name="SearchBar" Padding="12,10"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                  IsVisible="{Binding Downloads.HasDownloads}">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Name="SearchBox" Watermark="Search by name or URL"
                       Text="{Binding Downloads.SearchQuery}" />
              <ComboBox Grid.Column="1" Name="StatusFilterBox" MinWidth="120"
                        ItemsSource="{Binding Downloads.StatusFilterOptions}"
                        SelectedItem="{Binding Downloads.StatusFilter, Mode=TwoWay}" />
              <ComboBox Grid.Column="2" Name="DateFilterBox" MinWidth="120"
                        ItemsSource="{Binding Downloads.DateFilterOptions}"
                        SelectedItem="{Binding Downloads.DateFilter, Mode=TwoWay}" />
            </Grid>
          </Border>

          <Panel Grid.Row="1">

          <!-- Downloads list: sortable / reorderable / resizable columns, single-selection, virtualized. -->
          <DataGrid Name="DownloadsGrid"
                    IsVisible="{Binding Downloads.ShowGrid}"
                    ItemsSource="{Binding Downloads.Downloads}"
                    SelectedItem="{Binding Downloads.SelectedDownload, Mode=TwoWay}">
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Resume" Command="{Binding Downloads.ResumeCommand}">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IconPlay}" Width="12" Height="12" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Pause" Command="{Binding Downloads.PauseCommand}">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IconPause}" Width="12" Height="12" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Renew expired link…" Command="{Binding Downloads.RenewCommand}" />
                <Separator />
                <MenuItem Header="Open file" Command="{Binding Downloads.OpenFileCommand}">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IconFile}" Width="12" Height="12" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Open containing folder" Command="{Binding Downloads.OpenFolderCommand}" />
                <MenuItem Header="Copy link" Command="{Binding Downloads.CopyLinkCommand}" />
                <Separator />
                <MenuItem Header="Remove from list" Command="{Binding Downloads.RemoveCommand}">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IconTrash}" Width="12" Height="12" /></MenuItem.Icon>
                </MenuItem>
              </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
              <!-- Name (+ file-type icon and source sub-line) -->
              <DataGridTemplateColumn Header="Name" Width="*" MinWidth="220" CanUserSort="True" SortMemberPath="FileName">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:DownloadRowViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                      <Border Classes="FileTile"
                              Background="{Binding Category, Converter={x:Static conv:CategoryResourceConverter.Instance}, ConverterParameter=background}">
                        <PathIcon Width="15" Height="15"
                                  Data="{Binding Category, Converter={x:Static conv:CategoryResourceConverter.Instance}, ConverterParameter=geometry}"
                                  Foreground="{Binding Category, Converter={x:Static conv:CategoryResourceConverter.Instance}, ConverterParameter=foreground}" />
                      </Border>
                      <StackPanel VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Classes="FileName" Text="{Binding FileName}" AutomationProperties.Name="{Binding FileName}" ToolTip.Tip="{Binding FileName}" />
                        <TextBlock Classes="FileSub" Text="{Binding SubLine}" />
                      </StackPanel>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- Size -->
              <DataGridTemplateColumn Header="Size" Width="92" CanUserSort="True" SortMemberPath="TotalBytes">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:DownloadRowViewModel">
                    <TextBlock Classes="Muted" Text="{Binding SizeDisplay}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- Status: coloured label + inline mini progress -->
              <DataGridTemplateColumn Header="Status" Width="172" CanUserSort="True" SortMemberPath="ProgressSortKey">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:DownloadRowViewModel">
                    <StackPanel VerticalAlignment="Center" Spacing="4"
                                Classes.s-dl="{Binding IsDownloading}"
                                Classes.s-pause="{Binding IsPaused}"
                                Classes.s-done="{Binding IsCompleted}"
                                Classes.s-err="{Binding IsError}"
                                Classes.s-queue="{Binding IsQueued}">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Classes="StatusDot" />
                        <TextBlock Classes="StatusLabel" Text="{Binding StatusLabel}" />
                      </StackPanel>
                      <ProgressBar Classes="Mini" Classes.paused="{Binding IsPaused}"
                                   Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"
                                   IsVisible="{Binding ShowProgressBar}" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- Speed -->
              <DataGridTemplateColumn Header="Speed" Width="96" CanUserSort="True" SortMemberPath="SpeedDisplay">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:DownloadRowViewModel">
                    <TextBlock Classes="Muted" Text="{Binding SpeedDisplay}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- ETA -->
              <DataGridTemplateColumn Header="ETA" Width="84" CanUserSort="True" SortMemberPath="EtaDisplay">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:DownloadRowViewModel">
                    <TextBlock Classes="Dimmed" Text="{Binding EtaDisplay}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- Added -->
              <DataGridTemplateColumn Header="Added" Width="96" CanUserSort="True" SortMemberPath="AddedSortKey">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:DownloadRowViewModel">
                    <TextBlock Classes="Dimmed" Text="{Binding AddedDisplay}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Empty state -->
          <StackPanel Name="EmptyState" IsVisible="{Binding Downloads.ShowEmptyState}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="340" Spacing="6">
            <Border Width="64" Height="64" CornerRadius="18" HorizontalAlignment="Center" Margin="0,0,0,12"
                    Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
              <PathIcon Data="{StaticResource IconDownload}" Width="28" Height="28" Foreground="{DynamicResource AccentHoverBrush}" />
            </Border>
            <TextBlock Text="No downloads yet" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
            <TextBlock Text="Paste a URL, drag a link here, or use the browser extension to start your first download."
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFaintBrush}" />
            <Button Classes="App Accent" HorizontalAlignment="Center" Margin="0,12,0,0"
                    Command="{Binding NewDownloadCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <PathIcon Data="{StaticResource IconPlus}" Width="12" Height="12" />
                <TextBlock Text="New URL" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Loading state -->
          <StackPanel Name="LoadingState" IsVisible="{Binding Downloads.ShowLoading}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <ProgressBar IsIndeterminate="True" Width="160" />
            <TextBlock Text="Loading your downloads…" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFaintBrush}" />
          </StackPanel>

          <!-- Error state -->
          <StackPanel Name="ErrorState" IsVisible="{Binding Downloads.ShowError}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="340" Spacing="6">
            <Border Width="64" Height="64" CornerRadius="18" HorizontalAlignment="Center" Margin="0,0,0,12"
                    Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
              <PathIcon Data="{StaticResource IconInfo}" Width="28" Height="28" Foreground="{DynamicResource RedBrush}" />
            </Border>
            <TextBlock Text="Something went wrong" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
            <TextBlock Text="{Binding Downloads.LoadError}" TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource TextFaintBrush}" />
            <Button Classes="App" HorizontalAlignment="Center" Margin="0,12,0,0" Content="Try again"
                    Command="{Binding Downloads.RetryLoadCommand}" />
          </StackPanel>

          <!-- Filtered-empty state -->
          <StackPanel Name="FilteredEmptyState" IsVisible="{Binding Downloads.ShowFilteredEmpty}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320" Spacing="6">
            <TextBlock Text="Nothing here" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextDimBrush}" />
            <TextBlock Text="No downloads match this view. Pick another category or add a download."
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFaintBrush}" />
          </StackPanel>
          </Panel>
        </Grid>
      </Border>

      <!-- Resize handle between list and detail (only meaningful while the detail pane itself shows) -->
      <GridSplitter Grid.Column="2" Name="PaneSplitter" Width="4" ResizeDirection="Columns"
                    Background="Transparent" HorizontalAlignment="Center" IsVisible="{Binding DetailVisible}" />

      <!-- Detail pane (per-download detail — TASK-054): shown only once a download is selected, and only
           while the user hasn't hidden it with the toolbar toggle — it starts out of the way rather than
           always reserving its column with an empty "no download selected" placeholder. -->
      <Border Grid.Column="3" Name="DetailPane" Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
              IsVisible="{Binding DetailVisible}">
        <views:DownloadDetailView DataContext="{Binding Detail}" />
      </Border>
    </Grid>
  </DockPanel>

  <!-- ===== Command palette overlay (TASK-056) ===== -->
  <Border Name="PaletteOverlay" DataContext="{Binding Palette}" x:DataType="vm:CommandPaletteViewModel"
          IsVisible="{Binding IsOpen}" Background="#66000000">
    <Border Width="560" MaxHeight="420" VerticalAlignment="Top" Margin="0,120,0,0"
            HorizontalAlignment="Center" Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}" BoxShadow="0 18 50 0 #40000000">
      <DockPanel Margin="12">
        <TextBox DockPanel.Dock="Top" Name="PaletteSearch" Watermark="Type a command…"
                 Text="{Binding Query, Mode=TwoWay}" FontSize="14" Margin="0,0,0,8" />
        <ListBox Name="PaletteResults" ItemsSource="{Binding Results}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                 MaxHeight="320" Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:PaletteCommand">
              <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding Group}" Foreground="{DynamicResource TextFaintBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
              </DockPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </Border>
</Panel>
</Window>
