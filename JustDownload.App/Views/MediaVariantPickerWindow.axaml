<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustDownload.App.ViewModels"
        x:Class="JustDownload.App.Views.MediaVariantPickerWindow"
        x:DataType="vm:MediaVariantPickerViewModel"
        Title="Choose quality"
        Width="460" SizeToContent="Height"
        MinWidth="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CardBrush}">

  <StackPanel Margin="20" Spacing="14">

    <TextBlock Text="Add media" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />

    <!-- Media URL -->
    <StackPanel Spacing="5">
      <TextBlock Text="URL" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
      <TextBox Name="UrlBox" Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Watermark="https://example.com/ video page or stream" />
    </StackPanel>

    <!-- Loading / message states -->
    <TextBlock Text="Reading media…" IsVisible="{Binding IsLoading}" Foreground="{DynamicResource TextDimBrush}" />
    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
               IsVisible="{Binding Message, Converter={x:Static ObjectConverters.IsNotNull}}"
               Foreground="{DynamicResource TextDimBrush}" />

    <!-- Video quality -->
    <StackPanel Spacing="5" IsVisible="{Binding HasVariants}">
      <TextBlock Text="Quality" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
      <ComboBox Name="QualityBox" ItemsSource="{Binding Variants}" SelectedItem="{Binding SelectedVariant, Mode=TwoWay}"
                HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:VariantOption">
            <TextBlock Text="{Binding Label}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <!-- Audio rendition (separate streams) -->
    <StackPanel Spacing="5" IsVisible="{Binding HasAudio}">
      <TextBlock Text="Audio" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
      <ComboBox Name="AudioBox" ItemsSource="{Binding AudioVariants}" SelectedItem="{Binding SelectedAudio, Mode=TwoWay}"
                HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:AudioOption">
            <TextBlock Text="{Binding Label}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <!-- Output container -->
    <StackPanel Spacing="5" IsVisible="{Binding HasVariants}">
      <TextBlock Text="Container" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
      <ComboBox Name="ContainerBox" ItemsSource="{Binding Containers}" SelectedItem="{Binding SelectedContainer, Mode=TwoWay}"
                HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Actions -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Classes="App Ghost" Content="Cancel" Click="OnCancel" />
      <Button Classes="App Accent" Content="Download" Click="OnConfirm" IsEnabled="{Binding CanConfirm}" />
    </StackPanel>
  </StackPanel>
</Window>
