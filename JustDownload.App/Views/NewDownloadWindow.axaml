<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustDownload.App.ViewModels"
        x:Class="JustDownload.App.Views.NewDownloadWindow"
        x:DataType="vm:NewDownloadViewModel"
        Title="New download"
        Width="520" SizeToContent="Height"
        MinWidth="460"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CardBrush}">

  <Window.Resources>
    <StreamGeometry x:Key="IconFolder">M2,3.5 H6.5 L8,5 H14 V12.5 H2 Z</StreamGeometry>
  </Window.Resources>

  <StackPanel Margin="20" Spacing="14">

    <!-- Header -->
    <TextBlock Text="New download" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />

    <!-- Generic/non-field detection failure (not tied to a specific input) — centered, wraps, red -->
    <TextBlock Text="{Binding DetectionMessage}" IsVisible="{Binding DetectionMessageIsError}"
               TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Stretch"
               FontSize="12" Foreground="{DynamicResource RedBrush}" />

    <!-- URL -->
    <StackPanel Spacing="5">
      <TextBlock Text="URL" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
      <TextBox Name="UrlBox" Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Watermark="https://example.com/file.zip" />
      <TextBlock Text="{Binding UrlError}" IsVisible="{Binding UrlError, Converter={x:Static ObjectConverters.IsNotNull}}"
                 FontSize="11" Foreground="{DynamicResource RedBrush}" />
      <Border IsVisible="{Binding UrlWarning, Converter={x:Static ObjectConverters.IsNotNull}}"
              BorderBrush="{DynamicResource RedBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6">
        <TextBlock Text="{Binding UrlWarning}" TextWrapping="Wrap" FontSize="11.5"
                   Foreground="{DynamicResource RedBrush}" />
      </Border>
    </StackPanel>

    <!-- File name + Category -->
    <Grid ColumnDefinitions="*,Auto" >
      <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,12,0">
        <TextBlock Text="File name" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
        <TextBox Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Text="{Binding FileNameError}"
                   IsVisible="{Binding FileNameError, Converter={x:Static ObjectConverters.IsNotNull}}"
                   FontSize="11" Foreground="{DynamicResource RedBrush}" />
      </StackPanel>
      <StackPanel Grid.Column="1" Spacing="5" Width="170">
        <TextBlock Text="Category" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" />
      </StackPanel>
    </Grid>

    <!-- Save to -->
    <StackPanel Spacing="5">
      <TextBlock Text="Save to" FontSize="12" Foreground="{DynamicResource TextDimBrush}" />
      <Grid ColumnDefinitions="*,Auto" >
        <TextBox Grid.Column="0" Margin="0,0,8,0"
                 Text="{Binding SaveToFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <Button Grid.Column="1" Name="BrowseButton" Classes="App" Click="OnBrowse">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Data="{StaticResource IconFolder}" Width="13" Height="13" />
            <TextBlock Text="Browse" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
      <TextBlock Text="{Binding FolderError}"
                 IsVisible="{Binding FolderError, Converter={x:Static ObjectConverters.IsNotNull}}"
                 FontSize="11" Foreground="{DynamicResource RedBrush}" />
      <Border IsVisible="{Binding DuplicateWarning, Converter={x:Static ObjectConverters.IsNotNull}}"
              BorderBrush="{DynamicResource RedBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6">
        <TextBlock Text="{Binding DuplicateWarning}" TextWrapping="Wrap" FontSize="11.5"
                   Foreground="{DynamicResource TextDimBrush}" />
      </Border>
    </StackPanel>

    <!-- Segmentation / proxy-override / alternate-URLs checkboxes: tightly spaced as one group (AC: no
         large gap between them), the outer dialog's Spacing="14" still separates the group from its
         neighbors above/below. -->
    <StackPanel Spacing="4">
      <!-- Segmentation toggle (the size/resumability status that used to sit here now lives in the footer,
           in the same spot "Detecting…" occupies while in progress) -->
      <CheckBox IsChecked="{Binding UseSegmentation, Mode=TwoWay}"
                Content="{Binding ConnectionsHint}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" />

      <!-- Per-download proxy override (TASK-153) -->
      <CheckBox IsChecked="{Binding UseProxyOverride, Mode=TwoWay}"
                Content="Use a different proxy for this download"
                Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
      <StackPanel Spacing="8" IsVisible="{Binding UseProxyOverride}" Margin="22,4,0,0">
        <Grid ColumnDefinitions="120,*,90">
          <ComboBox Grid.Column="0" ItemsSource="{Binding ProxyKinds}"
                    SelectedItem="{Binding OverrideProxyKind, Mode=TwoWay}" HorizontalAlignment="Stretch"
                    Margin="0,0,8,0" />
          <TextBox Grid.Column="1" Watermark="Proxy host" Text="{Binding OverrideProxyHost, Mode=TwoWay}"
                   Margin="0,0,8,0" />
          <TextBox Grid.Column="2" Watermark="Port"
                   Text="{Binding OverrideProxyPort, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="*,*,*">
          <TextBox Grid.Column="0" Watermark="Username (optional)"
                   Text="{Binding OverrideProxyUsername, Mode=TwoWay}" Margin="0,0,8,0" />
          <TextBox Grid.Column="1" Watermark="Domain (optional)"
                   Text="{Binding OverrideProxyDomain, Mode=TwoWay}" Margin="0,0,8,0" />
          <TextBox Grid.Column="2" Watermark="Password" PasswordChar="•"
                   Text="{Binding OverrideProxyPassword, Mode=TwoWay}" />
        </Grid>
        <TextBlock Text="{Binding ProxyOverrideError}" FontSize="11"
                   IsVisible="{Binding ProxyOverrideError, Converter={x:Static ObjectConverters.IsNotNull}}"
                   Foreground="{DynamicResource RedBrush}" />
      </StackPanel>

      <!-- Alternate mirror URLs (TASK-144) -->
      <CheckBox IsChecked="{Binding UseAlternateUrls, Mode=TwoWay}"
                Content="Add alternate mirror URLs"
                Foreground="{DynamicResource TextDimBrush}" FontSize="12" />
      <StackPanel Spacing="5" IsVisible="{Binding UseAlternateUrls}" Margin="22,4,0,0">
        <TextBlock Text="One URL per line. Tried in order if the main URL fails." FontSize="11"
                   Foreground="{DynamicResource TextFaintBrush}" />
        <TextBox Text="{Binding AlternateUrlsText, Mode=TwoWay}" AcceptsReturn="True" Height="70"
                 TextWrapping="Wrap" Watermark="https://mirror1.example.com/file.zip" />
      </StackPanel>
    </StackPanel>

    <!-- Footer -->
    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,4,0,0">
      <TextBlock Grid.Column="0" Text="Detecting…" VerticalAlignment="Center" FontWeight="Bold"
                 IsVisible="{Binding IsDetecting}" FontSize="11.5" Foreground="{DynamicResource GreenBrush}" />
      <TextBlock Grid.Column="0" Text="{Binding DetectionMessage}" VerticalAlignment="Center" FontWeight="Bold"
                 IsVisible="{Binding IsDetectionInfoVisible}" FontSize="11.5"
                 Foreground="{DynamicResource GreenBrush}" Classes.NotResumable="{Binding IsNotResumable}">
        <TextBlock.Styles>
          <Style Selector="TextBlock.NotResumable">
            <Setter Property="Foreground" Value="{DynamicResource AmberBrush}" />
          </Style>
        </TextBlock.Styles>
      </TextBlock>
      <Button Grid.Column="2" Classes="App" Content="Add paused" Margin="0,0,8,0"
              Command="{Binding AddPausedCommand}" />
      <Button Grid.Column="3" Classes="App Accent" Content="Download now"
              Command="{Binding DownloadNowCommand}" IsDefault="True" />
    </Grid>
  </StackPanel>
</Window>
