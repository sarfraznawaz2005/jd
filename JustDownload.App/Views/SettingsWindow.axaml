<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustDownload.App.ViewModels.Settings"
        xmlns:vmapp="using:JustDownload.App.ViewModels"
        xmlns:views="using:JustDownload.App.Views"
        xmlns:conv="using:JustDownload.App.Converters"
        x:Class="JustDownload.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="760" Height="560"
        MinWidth="640" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

  <Window.DataTemplates>

    <!-- General -->
    <DataTemplate DataType="vm:GeneralSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="General" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Theme" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="List density" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding Densities}" SelectedItem="{Binding Density, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Default video quality" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding VideoQualities}" SelectedItem="{Binding DefaultVideoQuality, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Default output container" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding Containers}" SelectedItem="{Binding DefaultContainer, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Default download folder" Classes="StatKey" />
          <TextBlock Text="Leave empty to use the OS Downloads folder. New downloads default here."
                     Classes="SettingsHint" />
          <Grid ColumnDefinitions="360,Auto" ColumnSpacing="8" HorizontalAlignment="Left">
            <TextBox Grid.Column="0"
                     Text="{Binding DefaultDownloadFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            <Button Grid.Column="1" Classes="App" Click="OnBrowseDefaultFolder">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconFolder}" Width="13" Height="13" />
                <TextBlock Text="Browse" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>
          <TextBlock Text="{Binding DefaultDownloadFolderError}"
                     IsVisible="{Binding DefaultDownloadFolderError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
          <TextBlock Text="{Binding DefaultDownloadFolderHint}"
                     IsVisible="{Binding DefaultDownloadFolderHint, Converter={x:Static ObjectConverters.IsNotNull}}"
                     Classes="SettingsHint" />
        </StackPanel>
        <StackPanel Spacing="10">
          <TextBlock Text="Startup &amp; tray" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
            <TextBlock Text="Start minimized in the system tray" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding CloseToTray, Mode=TwoWay}" />
            <TextBlock Text="Close to tray instead of quitting" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="The tray icon keeps JustDownload running; choose Quit from its menu to exit."
                     Classes="SettingsHint" />
          <StackPanel Orientation="Horizontal" Spacing="12" IsEnabled="{Binding CanLaunchAtStartup}">
            <ToggleSwitch IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}" />
            <TextBlock Text="Launch JustDownload at login" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}" />
            <TextBlock Text="Show a notification when a download finishes or fails" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Clipboard" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding MonitorClipboard, Mode=TwoWay}" />
            <TextBlock Text="Offer to download links copied to the clipboard" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="When on, copying a http(s)/ftp(s) link opens the New URL dialog prefilled."
                     Classes="SettingsHint" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Connections -->
    <DataTemplate DataType="vm:ConnectionsSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Connections" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Default connections per download" Classes="StatKey" />
          <TextBlock Text="Dynamic segmentation splits each download into this many connections (1–32)."
                     Classes="SettingsHint" />
          <NumericUpDown Value="{Binding ConnectionsPerDownload, Mode=TwoWay}"
                         Increment="1" Width="160" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding ConnectionsPerDownloadError}"
                     IsVisible="{Binding ConnectionsPerDownloadError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Maximum concurrent downloads" Classes="StatKey" />
          <NumericUpDown Value="{Binding MaxConcurrentDownloads, Mode=TwoWay}"
                         Increment="1" Width="160" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding MaxConcurrentDownloadsError}"
                     IsVisible="{Binding MaxConcurrentDownloadsError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Global speed limit" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding SpeedLimited, Mode=TwoWay}" OnContent="Limited" OffContent="Unlimited" />
            <NumericUpDown Value="{Binding SpeedLimitMegabytesPerSecond, Mode=TwoWay}" Increment="0.5"
                           IsEnabled="{Binding SpeedLimited}" Width="140" />
            <TextBlock Text="MB/s" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
          </StackPanel>
          <TextBlock Text="{Binding SpeedLimitError}"
                     IsVisible="{Binding SpeedLimitError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
          <TextBlock Text="{Binding SpeedLimitDisplay, StringFormat='Current: {0}'}" Classes="SettingsHint" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Proxy -->
    <DataTemplate DataType="vm:ProxySettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Proxy" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Proxy type" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding ProxyKinds}" SelectedItem="{Binding ProxyKind, Mode=TwoWay}"
                    Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="10" IsVisible="{Binding RequiresHost}">
          <StackPanel Spacing="4">
            <TextBlock Text="Host" Classes="StatKey" />
            <TextBox Text="{Binding Host, Mode=TwoWay}" Width="360" HorizontalAlignment="Left" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Port" Classes="StatKey" />
            <NumericUpDown Value="{Binding Port, Mode=TwoWay}" Increment="1" Width="160" HorizontalAlignment="Left" />
          </StackPanel>
          <TextBlock Text="Authentication (optional — Basic, Digest, or NTLM is negotiated automatically)"
                     Classes="SettingsHint" />
          <StackPanel Spacing="4">
            <TextBlock Text="Username" Classes="StatKey" />
            <TextBox Text="{Binding Username, Mode=TwoWay}" Width="280" HorizontalAlignment="Left" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Password" Classes="StatKey" />
            <TextBox Text="{Binding Password, Mode=TwoWay}" PasswordChar="●" Width="280" HorizontalAlignment="Left" />
            <TextBlock IsVisible="{Binding HasStoredPassword}"
                       Text="A password is saved. Leave this blank to keep it, or type a new one to replace it."
                       Classes="SettingsHint" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Domain (NTLM, optional)" Classes="StatKey" />
            <TextBox Text="{Binding Domain, Mode=TwoWay}" Width="280" HorizontalAlignment="Left" />
          </StackPanel>
        </StackPanel>
        <TextBlock Text="{Binding ProxyError}"
                   IsVisible="{Binding ProxyError, Converter={x:Static ObjectConverters.IsNotNull}}"
                   FontSize="11" Foreground="{DynamicResource RedBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Button Classes="App Accent" Content="Save proxy" Command="{Binding SaveCommand}" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                     IsVisible="{Binding Status, Converter={x:Static ObjectConverters.IsNotNull}}"
                     Foreground="{DynamicResource GreenBrush}" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Categories -->
    <DataTemplate DataType="vm:CategoriesSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Categories" Classes="SettingsHeading" />
        <StackPanel Orientation="Horizontal" Spacing="12">
          <ToggleSwitch IsChecked="{Binding OrganizeByCategory, Mode=TwoWay}" />
          <TextBlock Text="Move completed downloads into a per-category subfolder" VerticalAlignment="Center"
                     Foreground="{DynamicResource TextBrush}" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Organized root folder" Classes="StatKey" />
          <TextBlock Text="Leave empty to organize in place (next to where each file was downloaded)."
                     Classes="SettingsHint" />
          <TextBox Text="{Binding OrganizedRootDirectory, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="360"
                   HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Category folders" Classes="StatKey" />
          <ItemsControl ItemsSource="{Binding Folders}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CategoriesSettingsViewModel+CategoryFolderRow">
                <Grid ColumnDefinitions="160,*" Margin="0,3">
                  <TextBlock Grid.Column="0" Text="{Binding Category}" Foreground="{DynamicResource TextBrush}" />
                  <TextBlock Grid.Column="1" Text="{Binding Folder}" Foreground="{DynamicResource TextDimBrush}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Browsers (extension / native-host integration) -->
    <DataTemplate DataType="vmapp:BrowsersViewModel">
      <views:BrowsersView />
    </DataTemplate>

    <!-- Info (Proxy / Authentication / Advanced) -->
    <DataTemplate DataType="vm:InfoSettingsViewModel">
      <StackPanel Spacing="14">
        <TextBlock Text="{Binding Heading}" Classes="SettingsHeading" />
        <ItemsControl ItemsSource="{Binding Paragraphs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="x:String">
              <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,8"
                         Foreground="{DynamicResource TextDimBrush}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>

  </Window.DataTemplates>

  <Grid ColumnDefinitions="208,*">

    <!-- Section nav rail -->
    <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
      <StackPanel Name="SettingsNav" Margin="8,14">
        <TextBlock Classes="NavLabel" Text="SETTINGS" />
        <ItemsControl ItemsSource="{Binding Sections}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SettingsSectionViewModel">
              <Button Classes="Nav" Classes.Active="{Binding IsSelected}"
                      Command="{Binding #SettingsNav.((vm:SettingsViewModel)DataContext).SelectCommand}"
                      CommandParameter="{Binding}">
                <Grid ColumnDefinitions="Auto,*">
                  <PathIcon Grid.Column="0" Width="15" Height="15" Margin="0,0,10,0"
                            Data="{Binding IconKey, Converter={x:Static conv:ResourceKeyConverter.Instance}}"
                            Foreground="{DynamicResource TextFaintBrush}" />
                  <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" />
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <!-- Selected section content -->
    <ScrollViewer Grid.Column="1">
      <ContentControl Margin="28,24" Content="{Binding SelectedSection.Content}" />
    </ScrollViewer>
  </Grid>
</Window>
