<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustDownload.App.ViewModels.Settings"
        xmlns:vmapp="using:JustDownload.App.ViewModels"
        xmlns:views="using:JustDownload.App.Views"
        xmlns:conv="using:JustDownload.App.Converters"
        x:Class="JustDownload.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="760" Height="560"
        MinWidth="640" MinHeight="460"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

  <Window.DataTemplates>

    <!-- General -->
    <DataTemplate DataType="vm:GeneralSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="General" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Theme" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="List density" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding Densities}" SelectedItem="{Binding Density, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Default video quality" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding VideoQualities}" SelectedItem="{Binding DefaultVideoQuality, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Default output container" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding Containers}" SelectedItem="{Binding DefaultContainer, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Default download folder" Classes="StatKey" />
          <TextBlock Text="Leave empty to use the OS Downloads folder. New downloads default here."
                     Classes="SettingsHint" />
          <Grid ColumnDefinitions="360,Auto" ColumnSpacing="8" HorizontalAlignment="Left">
            <TextBox Grid.Column="0"
                     Text="{Binding DefaultDownloadFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            <Button Grid.Column="1" Classes="App" Click="OnBrowseDefaultFolder">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconFolder}" Width="13" Height="13" />
                <TextBlock Text="Browse" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>
          <TextBlock Text="{Binding DefaultDownloadFolderError}"
                     IsVisible="{Binding DefaultDownloadFolderError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
          <TextBlock Text="{Binding DefaultDownloadFolderHint}"
                     IsVisible="{Binding DefaultDownloadFolderHint, Converter={x:Static ObjectConverters.IsNotNull}}"
                     Classes="SettingsHint" />
        </StackPanel>
        <StackPanel Spacing="10">
          <TextBlock Text="Startup &amp; tray" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
            <TextBlock Text="Start minimized in the system tray" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding CloseToTray, Mode=TwoWay}" />
            <TextBlock Text="Close to tray instead of quitting" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="The tray icon keeps JustDownload running; choose Quit from its menu to exit."
                     Classes="SettingsHint" />
          <StackPanel Orientation="Horizontal" Spacing="12" IsEnabled="{Binding CanLaunchAtStartup}">
            <ToggleSwitch IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}" />
            <TextBlock Text="Launch JustDownload at login" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}" />
            <TextBlock Text="Show a notification when a download finishes or fails" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding AutoExtractArchives, Mode=TwoWay}" />
            <TextBlock Text="Automatically extract .zip archives when they finish" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Clipboard" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding MonitorClipboard, Mode=TwoWay}" />
            <TextBlock Text="Offer to download links copied to the clipboard" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="When on, copying a http(s)/ftp(s) link opens the New URL dialog prefilled."
                     Classes="SettingsHint" />
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Legal" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding ShowTosNotice, Mode=TwoWay}" />
            <TextBlock Text="Show the terms-of-service notice before media downloads" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="Turning this off suppresses the one-time notice shown before the first HLS/DASH/video-audio download; turn it back on to see it again."
                     Classes="SettingsHint" TextWrapping="Wrap" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Video (TASK-162, locked decision D3) -->
    <DataTemplate DataType="vm:VideoSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Video" Classes="SettingsHeading" />
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding VideoCaptureEnabled, Mode=TwoWay}" />
            <TextBlock Text="Enable video capture/detection" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="Turns on the optional yt-dlp fallback for sites the in-house extractors can't reliably handle (e.g. YouTube/Facebook). Off by default. yt-dlp is never bundled — it only downloads, as a separate process, once you enable it here."
                     Classes="SettingsHint" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="10" IsVisible="{Binding VideoCaptureEnabled}">
          <TextBlock Text="yt-dlp" Classes="StatKey" />
          <TextBlock Text="yt-dlp is a separate, independently-licensed (public domain) tool invoked as a child process, the same way ffmpeg is. It's used only as a last resort, after every in-house extractor has declined."
                     Classes="SettingsHint" TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Classes="App Accent" Content="Download yt-dlp" Command="{Binding DownloadCommand}" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
          </StackPanel>
          <TextBlock Text="{Binding ErrorMessage}"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Connections -->
    <DataTemplate DataType="vm:ConnectionsSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Connections" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Default connections per download" Classes="StatKey" />
          <TextBlock Text="Dynamic segmentation splits each download into this many connections (1–32)."
                     Classes="SettingsHint" />
          <NumericUpDown Value="{Binding ConnectionsPerDownload, Mode=TwoWay}"
                         Increment="1" Width="160" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding ConnectionsPerDownloadError}"
                     IsVisible="{Binding ConnectionsPerDownloadError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Maximum concurrent downloads" Classes="StatKey" />
          <NumericUpDown Value="{Binding MaxConcurrentDownloads, Mode=TwoWay}"
                         Increment="1" Width="160" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding MaxConcurrentDownloadsError}"
                     IsVisible="{Binding MaxConcurrentDownloadsError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Global speed limit" Classes="StatKey" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding SpeedLimited, Mode=TwoWay}" OnContent="Limited" OffContent="Unlimited" />
            <NumericUpDown Value="{Binding SpeedLimitMegabytesPerSecond, Mode=TwoWay}" Increment="0.5"
                           IsEnabled="{Binding SpeedLimited}" Width="140" />
            <TextBlock Text="MB/s" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" />
          </StackPanel>
          <TextBlock Text="{Binding SpeedLimitError}"
                     IsVisible="{Binding SpeedLimitError, Converter={x:Static ObjectConverters.IsNotNull}}"
                     FontSize="11" Foreground="{DynamicResource RedBrush}" />
          <TextBlock Text="{Binding SpeedLimitDisplay, StringFormat='Current: {0}'}" Classes="SettingsHint" />
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Per-category limits" Classes="StatKey" />
          <TextBlock Text="Cap how many downloads of a type run at once so one kind doesn't hog bandwidth (0 = unlimited)."
                     Classes="SettingsHint" />
          <ItemsControl ItemsSource="{Binding CategoryLimits}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CategoryLimitItem">
                <Grid ColumnDefinitions="140,160" Margin="0,2">
                  <TextBlock Grid.Column="0" Text="{Binding Category}" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextBrush}" />
                  <NumericUpDown Grid.Column="1" Value="{Binding Limit, Mode=TwoWay}" Minimum="0"
                                 Maximum="{Binding $parent[ItemsControl].((vm:ConnectionsSettingsViewModel)DataContext).MaxCategoryConcurrent}"
                                 Increment="1" Width="150" HorizontalAlignment="Left" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Bandwidth schedule" Classes="StatKey" />
          <TextBlock Text="Apply a different speed cap by time of day (e.g. unlimited overnight). 24-hour HH:mm; 0 MB/s = unlimited; a window may wrap past midnight."
                     Classes="SettingsHint" TextWrapping="Wrap" />
          <ItemsControl ItemsSource="{Binding ScheduleRules}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:BandwidthRuleItem">
                <Grid ColumnDefinitions="70,20,70,90,Auto,Auto" Margin="0,3" ColumnSpacing="6">
                  <TextBox Grid.Column="0" Text="{Binding Start, Mode=TwoWay}" Watermark="22:00" />
                  <TextBlock Grid.Column="1" Text="to" VerticalAlignment="Center" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextDimBrush}" />
                  <TextBox Grid.Column="2" Text="{Binding End, Mode=TwoWay}" Watermark="06:00" />
                  <NumericUpDown Grid.Column="3" Value="{Binding LimitMegabytesPerSecond, Mode=TwoWay}"
                                 Minimum="0" Increment="0.5" />
                  <TextBlock Grid.Column="4" Text="MB/s" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextDimBrush}" />
                  <Button Grid.Column="5" Classes="App" Content="Remove"
                          Command="{Binding $parent[ItemsControl].((vm:ConnectionsSettingsViewModel)DataContext).RemoveScheduleRuleCommand}"
                          CommandParameter="{Binding}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Classes="App" Content="Add rule" HorizontalAlignment="Left"
                  Command="{Binding AddScheduleRuleCommand}" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Proxy -->
    <DataTemplate DataType="vm:ProxySettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Proxy" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Proxy type" Classes="StatKey" />
          <ComboBox ItemsSource="{Binding ProxyKinds}" SelectedItem="{Binding ProxyKind, Mode=TwoWay}"
                    Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="10" IsVisible="{Binding RequiresHost}">
          <StackPanel Spacing="4">
            <TextBlock Text="Host" Classes="StatKey" />
            <TextBox Text="{Binding Host, Mode=TwoWay}" Width="360" HorizontalAlignment="Left" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Port" Classes="StatKey" />
            <NumericUpDown Value="{Binding Port, Mode=TwoWay}" Increment="1" Width="160" HorizontalAlignment="Left" />
          </StackPanel>
          <TextBlock Text="Authentication (optional — Basic, Digest, or NTLM is negotiated automatically)"
                     Classes="SettingsHint" />
          <StackPanel Spacing="4">
            <TextBlock Text="Username" Classes="StatKey" />
            <TextBox Text="{Binding Username, Mode=TwoWay}" Width="280" HorizontalAlignment="Left" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Password" Classes="StatKey" />
            <TextBox Text="{Binding Password, Mode=TwoWay}" PasswordChar="●" Width="280" HorizontalAlignment="Left" />
            <TextBlock IsVisible="{Binding HasStoredPassword}"
                       Text="A password is saved. Leave this blank to keep it, or type a new one to replace it."
                       Classes="SettingsHint" />
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Domain (NTLM, optional)" Classes="StatKey" />
            <TextBox Text="{Binding Domain, Mode=TwoWay}" Width="280" HorizontalAlignment="Left" />
          </StackPanel>
        </StackPanel>
        <TextBlock Text="{Binding ProxyError}"
                   IsVisible="{Binding ProxyError, Converter={x:Static ObjectConverters.IsNotNull}}"
                   FontSize="11" Foreground="{DynamicResource RedBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Button Classes="App Accent" Content="Save proxy" Command="{Binding SaveCommand}" HorizontalAlignment="Left" />
          <Button Classes="App" Content="Test connection" Command="{Binding TestCommand}" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                     IsVisible="{Binding Status, Converter={x:Static ObjectConverters.IsNotNull}}"
                     Foreground="{DynamicResource GreenBrush}" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Categories -->
    <DataTemplate DataType="vm:CategoriesSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Categories" Classes="SettingsHeading" />
        <StackPanel Orientation="Horizontal" Spacing="12">
          <ToggleSwitch IsChecked="{Binding OrganizeByCategory, Mode=TwoWay}" />
          <TextBlock Text="Move completed downloads into a per-category subfolder" VerticalAlignment="Center"
                     Foreground="{DynamicResource TextBrush}" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Organized root folder" Classes="StatKey" />
          <TextBlock Text="Leave empty to organize in place (next to where each file was downloaded)."
                     Classes="SettingsHint" />
          <TextBox Text="{Binding OrganizedRootDirectory, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="360"
                   HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Category folders" Classes="StatKey" />
          <ItemsControl ItemsSource="{Binding Folders}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CategoriesSettingsViewModel+CategoryFolderRow">
                <Grid ColumnDefinitions="160,*" Margin="0,3">
                  <TextBlock Grid.Column="0" Text="{Binding Category}" Foreground="{DynamicResource TextBrush}" />
                  <TextBlock Grid.Column="1" Text="{Binding Folder}" Foreground="{DynamicResource TextDimBrush}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Browsers (extension / native-host integration) -->
    <DataTemplate DataType="vmapp:BrowsersViewModel">
      <views:BrowsersView />
    </DataTemplate>

    <!-- Info (Proxy / Authentication / Advanced) -->
    <DataTemplate DataType="vm:InfoSettingsViewModel">
      <StackPanel Spacing="14">
        <TextBlock Text="{Binding Heading}" Classes="SettingsHeading" />
        <ItemsControl ItemsSource="{Binding Paragraphs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="x:String">
              <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,8"
                         Foreground="{DynamicResource TextDimBrush}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>

    <!-- Authentication (TASK-126) -->
    <DataTemplate DataType="vm:AuthenticationSettingsViewModel">
      <StackPanel Spacing="14">
        <TextBlock Text="Authentication" Classes="SettingsHeading" />
        <TextBlock Text="Credentials are stored in the OS keychain (DPAPI / macOS Keychain / libsecret) — never in plain text. Here you can review and revoke what's saved; the secret values are never shown."
                   Classes="SettingsHint" TextWrapping="Wrap" />
        <TextBlock Text="No saved credentials." Classes="SettingsHint"
                   IsVisible="{Binding HasNoSavedCredentials}" />
        <ItemsControl ItemsSource="{Binding Credentials}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SavedCredentialRow">
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding Description}" VerticalAlignment="Center"
                           TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" />
                <Button Grid.Column="1" Classes="App" Content="Remove"
                        Command="{Binding $parent[ItemsControl].((vm:AuthenticationSettingsViewModel)DataContext).RemoveCommand}"
                        CommandParameter="{Binding}" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>

    <!-- Advanced (TASK-127) -->
    <DataTemplate DataType="vm:AdvancedSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Advanced" Classes="SettingsHeading" />
        <StackPanel Spacing="4">
          <TextBlock Text="Logging level" Classes="StatKey" />
          <TextBlock Text="How much detail the app logs. Debug is verbose for diagnostics; Warning is near-silent. Takes effect immediately."
                     Classes="SettingsHint" />
          <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding LogLevel, Mode=TwoWay}"
                    Width="200" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Run a program when a download finishes" Classes="StatKey" />
          <TextBlock Text="The completed file's full path is passed to it as an argument (no shell). Leave blank to disable."
                     Classes="SettingsHint" TextWrapping="Wrap" />
          <TextBox Text="{Binding OnCompletionCommand, Mode=TwoWay}"
                   Watermark="e.g. C:\Tools\scan.exe" HorizontalAlignment="Stretch" />
        </StackPanel>
        <StackPanel Spacing="8">
          <TextBlock Text="Privacy" Classes="StatKey" />
          <TextBlock Text="Logs redact credentials, tokens, and signed-URL query strings."
                     Classes="SettingsHint" TextWrapping="Wrap" />
          <TextBlock Text="There is no telemetry and no phone-home; the only network traffic is your downloads and an opt-in update check."
                     Classes="SettingsHint" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Error log" Classes="StatKey" />
          <TextBlock Text="Unhandled errors are recorded here (nothing else is logged to it) — useful when reporting a problem."
                     Classes="SettingsHint" TextWrapping="Wrap" />
          <Button Classes="App" Content="View error logs" Command="{Binding ViewErrorLogsCommand}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Updates (TASK-080, opt-in) -->
    <DataTemplate DataType="vm:UpdateSettingsViewModel">
      <StackPanel Spacing="18">
        <TextBlock Text="Updates" Classes="SettingsHeading" />
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding CurrentVersion, StringFormat='Current version: {0}'}" Classes="SettingsHint" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsChecked="{Binding AutoUpdateEnabled, Mode=TwoWay}" />
            <TextBlock Text="Check for updates" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" />
          </StackPanel>
          <TextBlock Text="Off by default. When on, a release's checksums are verified against an embedded signing key before anything is downloaded or launched — an unsigned or tampered release is always rejected."
                     Classes="SettingsHint" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Spacing="10" IsVisible="{Binding AutoUpdateEnabled}">
          <Grid ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Classes="App Accent" Content="Check for Updates"
                    Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="12,0,0,0"
                       TextWrapping="Wrap" Classes.Error="{Binding IsStatusError}"
                       Foreground="{DynamicResource TextDimBrush}">
              <TextBlock.Styles>
                <Style Selector="TextBlock.Error">
                  <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                </Style>
              </TextBlock.Styles>
            </TextBlock>
          </Grid>
        </StackPanel>
      </StackPanel>
    </DataTemplate>

  </Window.DataTemplates>

  <Grid ColumnDefinitions="208,*" RowDefinitions="*,Auto">

    <!-- Section nav rail -->
    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource SidebarBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
      <StackPanel Name="SettingsNav" Margin="8,14">
        <TextBlock Classes="NavLabel" Text="SETTINGS" />
        <ItemsControl ItemsSource="{Binding Sections}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SettingsSectionViewModel">
              <Button Classes="Nav" Classes.Active="{Binding IsSelected}"
                      Command="{Binding #SettingsNav.((vm:SettingsViewModel)DataContext).SelectCommand}"
                      CommandParameter="{Binding}">
                <Grid ColumnDefinitions="Auto,*">
                  <PathIcon Grid.Column="0" Width="15" Height="15" Margin="0,0,10,0"
                            Data="{Binding IconKey, Converter={x:Static conv:ResourceKeyConverter.Instance}}"
                            Foreground="{DynamicResource TextFaintBrush}" />
                  <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" />
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <!-- Selected section content -->
    <ScrollViewer Grid.Row="0" Grid.Column="1">
      <ContentControl Margin="28,24" Content="{Binding SelectedSection.Content}" />
    </ScrollViewer>

    <!-- Backup / restore footer (TASK-129) -->
    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
            Background="{DynamicResource SidebarBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
            Padding="16,10">
      <Grid ColumnDefinitions="Auto,Auto,*">
        <Button Grid.Column="0" Classes="App" Click="OnExportSettings" Margin="0,0,8,0">
          <TextBlock Text="Export settings…" VerticalAlignment="Center" />
        </Button>
        <Button Grid.Column="1" Classes="App" Click="OnImportSettings">
          <TextBlock Text="Import settings…" VerticalAlignment="Center" />
        </Button>
        <TextBlock Grid.Column="2" Text="{Binding TransferStatus}" VerticalAlignment="Center"
                   Margin="14,0,0,0" Foreground="{DynamicResource TextDimBrush}"
                   IsVisible="{Binding TransferStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </Grid>
    </Border>
  </Grid>
</Window>
